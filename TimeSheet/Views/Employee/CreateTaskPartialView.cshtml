@model EmployeeTaskDTO

@{
    ViewBag.Title = "Create Task";
}

<div class="modal fade" id="createTaskModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 rounded-4 shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold text-primary">Create New Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="CreateTaskForm" asp-action="CreateTask" asp-controller="Employee" method="post">
                    @Html.AntiForgeryToken()

                    <div class="text-danger text-space" asp-validation-summary="ModelOnly"></div>

                    <!-- TaskName -->
                    <div class="mb-3">
                        <label asp-for="TaskName" class="form-label fw-semibold"></label>
                        <input asp-for="TaskName" class="form-control" placeholder="Enter task name..." />
                        <span class="text-danger" asp-validation-for="TaskName"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Enter description..."></textarea>
                        <span class="text-danger" asp-validation-for="Description"></span>
                    </div>

                    <!-- Project (convert ViewData list to SelectList here) -->
                    <div class="mb-3">
                        <label asp-for="ProjectId" class="form-label fw-semibold"></label>
                        <select asp-for="ProjectId" class="form-control"
                                asp-items="@(new SelectList(ViewData["Projects"] as List<GetAllProjectsDTO>, "Id", "Name"))">
                            <option value="">-- Select Project --</option>
                        </select>
                        <span class="text-danger" asp-validation-for="ProjectId"></span>
                    </div>

                    <!-- Dates -->
                    <div class="d-flex justify-content-between gap-2 mb-3">
                        <div class="w-50">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate"  class="form-control" />
                            <span class="text-danger" asp-validation-for="StartDate" ></span>
                        </div>
                        <div class="w-50">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate"  class="form-control" />
                            <span class="text-danger" asp-validation-for="EndDate"></span>
                        </div>
                    </div>

                    

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Add Task</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
